# App
DEBUG=false

# Server
API_HOST=0.0.0.0
API_PORT=8000

# Frontend (used for CORS)
FRONTEND_URL=http://localhost:3000

# NeonDB — paste your connection string from the Neon dashboard
# Format: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Auth (Phase 2+)
JWT_SECRET=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Cookie settings (set COOKIE_SECURE=true in production over HTTPS)
COOKIE_NAME=access_token
COOKIE_SECURE=false
COOKIE_HTTPONLY=true
COOKIE_SAMESITE=lax

# Cloudinary (free tier is fine for development)
# Create a free account at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=appifylab/posts
MAX_UPLOAD_SIZE_MB=5
