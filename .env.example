# =============================================================================
# Local development
# =============================================================================

DEBUG=false

API_HOST=0.0.0.0
API_PORT=8000

# Primary frontend origin (fallback CORS origin when CORS_ALLOWED_ORIGINS is empty)
FRONTEND_URL=http://localhost:3000

# Optional comma-separated CORS allowlist for multiple frontends (local + deployed)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# NeonDB / PostgreSQL connection string
# Railway Postgres may use postgres:// — the app normalizes this automatically
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Auth
JWT_SECRET=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Cookies — local dev (same machine, HTTP)
COOKIE_NAME=access_token
COOKIE_SECURE=false
COOKIE_HTTPONLY=true
COOKIE_SAMESITE=lax

# Cloudinary (post images + profile avatars)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=appifylab/posts
MAX_UPLOAD_SIZE_MB=5

# =============================================================================
# Production example (Railway API + Vercel frontend on different domains)
# =============================================================================
#
# FRONTEND_URL=https://your-app.vercel.app
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
# DATABASE_URL=postgresql://...   # Neon or Railway Postgres
# JWT_SECRET=<long-random-secret>
# COOKIE_SECURE=true
# COOKIE_SAMESITE=none
# CLOUDINARY_CLOUD_NAME=...
# CLOUDINARY_API_KEY=...
# CLOUDINARY_API_SECRET=...
#
# Railway sets PORT automatically — do not hardcode it.
# Set the frontend NEXT_PUBLIC_API_URL to your Railway service URL, e.g.
# https://your-api.up.railway.app
